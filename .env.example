# Copy this file to .env.local and fill in real values from your Supabase project dashboard.

# Supabase — Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase — Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — Settings > API > Project API keys > service_role (server-only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma / PostgreSQL
# Settings > Database > Connection pooling > Transaction mode, port 6543 (runtime connection via PgBouncer)
DATABASE_URL=postgresql://postgres.your-project-id:password@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Settings > Database > Connection string, port 5432 (direct connection — migrations only)
DIRECT_URL=postgresql://postgres.your-project-id:password@aws-0-eu-north-1.pooler.supabase.com:5432/postgres
